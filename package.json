    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "firecrawl": "^4.15.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "next": "14.2.35",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
