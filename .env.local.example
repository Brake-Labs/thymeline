# Database
DATABASE_URL=postgresql://user:password@localhost:5432/thymeline

# Better Auth
BETTER_AUTH_SECRET=your-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Access control (comma-separated emails, empty = open access)
ALLOWED_EMAILS=

# LLM
LLM_API_KEY=
# Fast model — used for scraping, ingredient extraction, ambiguous resolution
LLM_MODEL=claude-haiku-4-5-20251001
# Capable model — used for discover, recipe generation, AI edit, search, cook ordering
# Defaults to claude-sonnet-4-6 if not set (more expensive but higher quality)
LLM_MODEL_CAPABLE=claude-sonnet-4-6

# Optional
FIRECRAWL_API_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAILS=
LOG_LEVEL=info
