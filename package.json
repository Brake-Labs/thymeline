    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^28.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
